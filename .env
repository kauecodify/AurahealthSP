# ==================== Application ====================
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
APP_URL=http://localhost:3000

# ==================== Database ====================
DB_USER=aura
DB_PASSWORD=aura123
DB_NAME=aurahealth
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:${DB_PORT}/${DB_NAME}
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ==================== Redis ====================
REDIS_PORT=6379
REDIS_URL=redis://redis:${REDIS_PORT}

# ==================== Kafka ====================
KAFKA_PORT=9092
KAFKA_BROKERS=kafka:${KAFKA_PORT}
KAFKA_CLIENT_ID=aura-api
KAFKA_GROUP_ID=aura-consumers

# ==================== Security ====================
JWT_SECRET=dev-secret-change-in-prod-min-32-chars-recommended
JWT_EXPIRES_IN=24h
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== Ports ====================
API_PORT=3001
FRONTEND_PORT=3000
NGINX_PORT=80

# ==================== AI/ML ====================
AI_CONFIDENCE_THRESHOLD=0.75
AI_MODEL_PATH=./models/triage-v1.onnx

# ==================== Monitoring ====================
METRICS_ENABLED=true
METRICS_PORT=9091